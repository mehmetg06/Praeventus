    "storyPrefix.dawn": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "With the morning light, the surface layer is just warming up."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sabah ışığıyla yüzey tabakası yeni ısınıyor."
          }
        }
      }
    },
    "storyPrefix.day": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daytime heating makes the atmosphere more visible."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gündüz ısınması atmosferi daha görünür hale getiriyor."
          }
        }
      }
    },
    "storyPrefix.sunset": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At sunset the surface begins to cool."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gün batımında yüzey soğumaya başlıyor."
          }
        }
      }
    },
    "storyPrefix.night": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At night, radiative cooling and weak mixing dominate."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gece radyatif soğuma ve zayıf karışım etkili."
          }
        }
      }
    },
