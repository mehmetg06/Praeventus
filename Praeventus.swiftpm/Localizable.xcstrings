    "story.clear": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressure is balanced. Humidity is low to moderate. The sky may stay clear and calm in the coming hours."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basınç dengeli. Nem düşük-orta seviyede. Önümüzdeki saatlerde gökyüzü açık ve sakin kalabilir."
          }
        }
      }
    },
    "story.partlyCloudy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The atmosphere is generally stable. Local clouds may form, but no strong precipitation signal stands out."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Atmosfer genel olarak kararlı. Yerel bulutlanma oluşabilir ama güçlü bir yağış sinyali öne çıkmıyor."
          }
        }
      }
    },
    "story.cloudy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Humidity and cloud cover are rising. If pressure does not drop sharply, precipitation risk may stay limited."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem ve bulut örtüsü artıyor. Basınç belirgin düşmezse yağış riski sınırlı kalabilir."
          }
        }
      }
    },
    "story.rain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Humidity is high and the precipitation signal is clear. Intermittent rain can be expected in the short term."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem yüksek ve yağış sinyali belirgin. Kısa vadede aralıklı yağış beklenebilir."
          }
        }
      }
    },
    "story.storm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Falling pressure, high humidity and wind together are destabilizing the atmosphere. Watch for sudden showers and storms."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basınç düşüşü, yüksek nem ve rüzgar birleşimi atmosferi kararsızlaştırıyor. Ani sağanak ve fırtına riski izlenmeli."
          }
        }
      }
    },
    "story.fog": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Surface humidity is high. With weak wind, visibility may drop and a fog layer can form."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüzey nemi yüksek. Rüzgar zayıf kaldığı için görüşte azalma ve sis tabakası oluşabilir."
          }
        }
      }
    },
    "story.snow": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The cold air profile is strengthening. With enough moisture, snow or sleet may occur."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Soğuk hava profili güçleniyor. Nem yeterli olursa kar veya karla karışık yağış görülebilir."
          }
        }
      }
    },
