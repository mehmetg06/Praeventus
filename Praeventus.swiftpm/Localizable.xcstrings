    "engineStory.storm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Humidity, low pressure and wind are acting together; the atmosphere is becoming unstable."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem, düşük basınç ve rüzgar aynı yönde çalışıyor; atmosfer kararsızlaşıyor."
          }
        }
      }
    },
    "engineStory.rain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The precipitation signal is clear. Cloud cover and humidity are rising together."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yağış sinyali belirgin. Bulut örtüsü ve nem birlikte artıyor."
          }
        }
      }
    },
    "engineStory.lowVisibility": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Surface humidity is high and mixing is weak; visibility may drop."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüzey nemi yüksek ve karışım zayıf; görüş düşebilir."
          }
        }
      }
    },
    "engineStory.cloudy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud cover is strong, but storm energy looks limited."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulut örtüsü kuvvetli fakat fırtına enerjisi sınırlı görünüyor."
          }
        }
      }
    },
    "engineStory.calm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressure and humidity are balanced; the atmosphere is in a calmer phase."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basınç ve nem dengeli; atmosfer daha sakin bir fazda."
          }
        }
      }
    },
    "engineStory.transition": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The atmosphere is in transition; small short-term changes may be felt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Atmosfer geçiş halinde; kısa vadede küçük değişimler hissedilebilir."
          }
        }
      }
    },
    "engineStory.windStrong": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wind is strong, making the felt conditions and cloud motion more pronounced."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rüzgar kuvvetli, hissedilen hava ve bulut hareketi belirginleşir."
          }
        }
      }
    },
    "engineStory.windWeak": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Because wind is weak, humidity may linger near the surface."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rüzgar zayıf olduğu için nem yüzeyde kalabilir."
          }
        }
      }
    },
