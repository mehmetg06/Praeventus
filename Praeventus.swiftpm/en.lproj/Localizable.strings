/* Scenario-aware narrative engine */
"narrative.clear.hot" = "Sky conditions look mostly clear, but the main story is heat: the air temperature is very high and direct sun can make exposure tiring quickly.";
"narrative.clear.cold" = "The sky is mostly clear, yet the air is on the cold side; open areas may feel crisp, especially in shade or after sunset.";
"narrative.clear.normal" = "The atmosphere looks settled and bright, with limited cloud or precipitation signal in the near term.";
"narrative.partlyCloudy" = "Clouds may pass through from time to time, but the overall setup is still fairly stable and not strongly rainy.";
"narrative.cloudy" = "Cloud cover is the dominant signal right now; the sky may feel closed in, although the rain signal depends on humidity and pressure support.";
"narrative.rain" = "Moisture and precipitation signals are aligned, so showers are plausible and surfaces may become wet in the short term.";
"narrative.storm" = "Instability, moisture and wind are combining, so sudden heavy rain, lightning or fast-changing conditions deserve attention.";
"narrative.fog" = "Low-level moisture is high and mixing is weak, so visibility can drop locally and travel may feel slower.";
"narrative.snow" = "The air profile is cold enough for wintry precipitation signals; slick surfaces are possible if moisture persists.";
"narrative.feels.extremeHeatWind" = "Even with wind, this is not a cooling scenario: at this temperature the breeze can feel like hot air movement, increase dehydration and make you feel warmer over time.";
"narrative.feels.extremeHeat" = "The body will struggle to cool efficiently in this heat, so the felt temperature can be dangerous even if the wind is light.";
"narrative.feels.hotHumid" = "Heat and humidity are working together; sweat evaporates more slowly, so it can feel heavier and warmer than the thermometer suggests.";
"narrative.feels.hotWind" = "The wind may not make the air feel cold; in hot weather it can dry you out faster and make sun exposure feel harsher.";
"narrative.feels.hot" = "The temperature is high enough that shade, hydration and slower outdoor pacing matter more than the headline condition.";
"narrative.feels.coldWind" = "Because the air is already cool, the wind can remove body heat faster and make it feel colder than the measured temperature.";
"narrative.feels.warmer" = "The apparent temperature is running above the actual reading, so it may feel warmer than the number on screen.";
"narrative.feels.cooler" = "The apparent temperature is below the actual reading, so it may feel cooler than the number on screen.";
"narrative.feels.neutral" = "The measured and felt temperatures are close, so comfort will depend more on sun, shade, clothing and activity level.";
"narrative.trend.warming" = "Temperatures trend upward over the next few hours, so the day may feel progressively warmer.";
"narrative.trend.cooling" = "Temperatures trend downward over the next few hours, so conditions may feel cooler later.";
"narrative.risk.extremeHeat" = "Heat stress is the priority risk: avoid long sun exposure, drink water often and watch for dizziness, headache or unusual fatigue.";
"narrative.risk.storm" = "Because storm risk is high, avoid exposed areas and be ready for rapid changes rather than relying on the current calm.";
"narrative.risk.visibility" = "Reduced visibility can be patchy, so driving or cycling may require extra distance and slower reactions.";
"narrative.risk.wind" = "Wind is strong enough to affect umbrellas, loose objects and exposed routes.";
"narrative.advice.extremeHeat" = "Prefer shade or indoor breaks, carry water, choose light clothing and avoid heavy exercise during the hottest part of the day.";
"narrative.advice.hot" = "Plan around heat: hydrate, use sunscreen and do demanding outdoor tasks earlier or later if possible.";
"narrative.advice.storm" = "If you need to go out, keep the trip flexible and move indoors at the first sign of thunder or sudden heavy rain.";
"narrative.advice.rain" = "A compact umbrella or waterproof layer is a good idea, especially for walking or public transport connections.";
"narrative.advice.snow" = "Dress in layers and watch for slippery spots on bridges, stairs and shaded roads.";
"narrative.advice.fog" = "Use extra time for travel and keep lights visible if you are driving or cycling.";
"narrative.advice.cold" = "A warm layer will help, especially if you will be outside for more than a few minutes.";
"narrative.advice.calm" = "Overall, normal outdoor plans look reasonable; just adjust clothing for the local breeze and time of day.";
"narrative.fetching" = "Fetching weather insight…";
