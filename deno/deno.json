{
  "imports": {
    "tz-lookup": "npm:tz-lookup@6.1.25"
  },
  "deploy": {
    "runtime": {
      "type": "dynamic",
      "entrypoint": "main.ts"
    }
  },
  "tasks": {
    "start": "deno run --allow-net --allow-env --unstable-kv main.ts",
    "dev": "deno run --watch --allow-net --allow-env --unstable-kv main.ts",
    "check": "deno check main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
